FROM python:3.12-slim

WORKDIR /app

# Install uv
RUN pip install uv

# Copy dependency files
COPY pyproject.toml .
COPY src/ src/

# Install dependencies
RUN uv sync --no-dev

# Expose API port
EXPOSE 8000

CMD ["uv", "run", "uvicorn", "orbit.backend.app:app", "--host", "0.0.0.0", "--port", "8000"]
